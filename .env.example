# LiveMatch environment example
# Copy this file to .env and replace values for your environment.
# Do not commit real secrets, passwords, bot tokens, or SMTP credentials.

# ---------------------------------------------------------------------------
# App URL
# ---------------------------------------------------------------------------
# Local Docker development:
APP_BASE_URL=http://localhost:5173

# Production example:
# APP_BASE_URL=https://livematch.vibestudio.work

# APP_BASE_URL is used for:
# - Telegram webhook URL: {APP_BASE_URL}/api/telegram/webhook/{secret}
# - email verification/reset links
# - public share links generated by backend helpers

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
# Keep empty when frontend and backend are served by the same origin/proxy.
# For local Vite dev through docker-compose, /api is proxied to backend.
VITE_API_URL=
VITE_DEV_API_PROXY=http://backend:8080

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
PORT=8080
DATABASE_URL=postgres://livematch:livematch@postgres:5432/livematch?sslmode=disable

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=livematch
POSTGRES_PASSWORD=livematch
POSTGRES_DB=livematch

# ---------------------------------------------------------------------------
# Backoffice superadmin
# ---------------------------------------------------------------------------
# Login at /backoffice.
# Change SUPERADMIN_PASSWORD before deploying to production.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-this-password

# ---------------------------------------------------------------------------
# SMTP email
# ---------------------------------------------------------------------------
# Required for admin registration verification and forgot password email.
# Leave empty only if you do not need email flows in local development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=LiveMatch

# Example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your-email@gmail.com
# SMTP_FROM_NAME=LiveMatch

# ---------------------------------------------------------------------------
# Telegram coin approval
# ---------------------------------------------------------------------------
# Used for Telegram notification and inline approve/reject buttons.
# Leave empty to disable Telegram alerts locally.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional. If empty, the system can generate/save a secret from Backoffice.
# If you set it manually, use a long random value with no spaces.
TELEGRAM_WEBHOOK_SECRET=

# After deploying production:
# 1. Set APP_BASE_URL=https://livematch.vibestudio.work
# 2. Set TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID
# 3. Open /backoffice
# 4. Click "ตั้งค่า Telegram webhook"

# ---------------------------------------------------------------------------
# Optional pgAdmin values
# ---------------------------------------------------------------------------
# docker-compose currently keeps pgAdmin commented out. Use these if enabled.
# PGADMIN_DEFAULT_EMAIL=admin@livematch.dev
# PGADMIN_DEFAULT_PASSWORD=change-this-password
