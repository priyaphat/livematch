# LiveMatch local environment

# App URLs
APP_BASE_URL=http://localhost:5173
VITE_API_URL=
VITE_DEV_API_PROXY=http://backend:8080

# Backend
PORT=8080
DATABASE_URL=postgres://livematch:livematch@postgres:5432/livematch?sslmode=disable

# PostgreSQL
POSTGRES_USER=livematch
POSTGRES_PASSWORD=livematch
POSTGRES_DB=livematch

# SMTP is required for register verification and forgot password.
# Example values only. Replace with your real SMTP provider settings.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=yourgmail@gmail.com
SMTP_FROM_NAME=LiveMatch

# Telegram Bot notification for new coin orders.
# Leave empty to disable local Telegram alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Backoffice login at /backoffice
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=12345678
